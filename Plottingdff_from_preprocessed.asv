%% PLOTTING LOCATION OF NEURONS IN THE SPECIFIC PLANES AS SCATTER PLOT TO 
%COMPARE THE SAMPLING 

% Extract neuron coordinates from both datasets
x1 = centroid1(:, 1);
y1 = centroid1(:, 2);
z1 = centroid1(:, 3);

x2 = centroid2(:, 1);
y2 = centroid2(:, 2);
z2 = centroid2(:, 3);

% Filter neurons for the first plane (z == 1)
plane1_indices1 = z1 == 1;
plane1_indices2 = z2 == 1;

% Apply filtering to get only neurons from the first plane
x1_plane1 = x1(plane1_indices1);
y1_plane1 = y1(plane1_indices1);

x2_plane1 = x2(plane1_indices2);
y2_plane1 = y2(plane1_indices2);

num_neurons1 = length(x1_plane1);
num_neurons2 = length(x2_plane1);

% Create a figure with 2 subplots
figure;

% Plot neurons from the first dataset
subplot(1, 2, 1);
scatter(x1_plane1, y1_plane1, 'filled', 'MarkerEdgeColor', 'k', 'MarkerFaceColor', 'r');
title('Neurons in Dataset 1 (Plane 1)');
axis equal;
grid on;

% Determine axis limits for text placement
x_limits1 = xlim;
y_limits1 = ylim;

% Add neuron count text to the bottom of the plot
text(mean(x_limits1), y_limits1(1) - (0.1 * diff(y_limits1)), ...
    sprintf('Number of neurons: %d', num_neurons1), ...
    'FontSize', 12, 'Color', 'k', 'FontWeight', 'bold', 'HorizontalAlignment', 'center');

% Plot neurons from the second dataset
subplot(1, 2, 2);
scatter(x2_plane1, y2_plane1, 'filled', 'MarkerEdgeColor', 'k', 'MarkerFaceColor', 'b');
title('Neurons in Dataset 2 (Plane 1)');
axis equal;
grid on;

% Determine axis limits for text placement
x_limits2 = xlim;
y_limits2 = ylim;

% Add neuron count text to the bottom of the plot
text(mean(x_limits2), y_limits2(1) - (0.1 * diff(y_limits2)), ...
    sprintf('Number of neurons: %d', num_neurons2), ...
    'FontSize', 12, 'Color', 'k', 'FontWeight', 'bold', 'HorizontalAlignment', 'center');

% Add a title for the entire figure
sgtitle('Comparison of Neuron Locations (Plane 1)');

% Optionally, adjust subplot spacing
subplot_adjustment = get(gcf, 'Position');
subplot_adjustment(3) = subplot_adjustment(3) * 1.2; % Increase figure width for better spacing
set(gcf, 'Position', subplot_adjustment);

