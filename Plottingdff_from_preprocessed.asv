%% Making Video of Calcium Activity framebyframe 
clc
close all
video_bool = 0;
avg_bool = 0;


% Apply the colormap to the current figure
colormap(redMap);

sizeRange = [10, 50];

cmap = hot;
caxis([0 1]);
numTimepoints = size(CalciumData_norm, 2);
numCells = size(CalciumData_norm, 1);
colorIndices = [];
activitySize = [];

%Loop through each frame

for frameIndex = 1:numTimepoints 
    currentFrameData = CalciumData_norm(:, frameIndex); 
    colorIndices(frameIndex,:) = round(currentFrameData * (size(cmap, 1) - 1)) + 1;
    activitySize(frameIndex, :) = currentFrameData*0 + sizeRange(1);    
end 

disp(size(CalciumData)); 

f1 = figure;
if video_bool
    writerObj = VideoWriter("videos_tryout_2");
    writerObj.FrameRate = 60;
    open(writerObj);
end


for frameIndex = 1:numTimepoints
    % Access the data for the current frame
    currentFrameData = CalciumData(:, frameIndex); 

    % Scatter plot all neurons for the current frame
    x = Centroid(:, 1);
    y = Centroid(:, 2);
    activity = currentFrameData(:);
    
    % Normalize activity values between 0 and 1
     minActivity = min(activity);
     maxActivity = max(activity);

if maxActivity ~= minActivity % Avoid division by zero
    Norm_activity = (activity - minActivity) / (maxActivity - minActivity);
else
    Norm_activity = zeros(size(activity)); % Handle case where all values are the same
end
    activitySize = Norm_activity * (sizeRange(2) - sizeRange(1)) + sizeRange(1);

    % activitySize = Norm_activity;
    % Choose a colormap (e.g., jet) and map activity values to color indices
    figure(f1)
    colors = cmap(colorIndices(frameIndex,:), :);
    scatter(x, y, activitySize, colors, "filled");
    colorbar;
    colormap hot 
    xlabel('X');
    ylabel('Y');
    title(['Activity Plot - Frame ', num2str(frameIndex)]);
%     set(gca,'Color','k')
    if video_bool
        frame = getframe(f1);
        for frame_index = 1:4
            writeVideo(writerObj,frame);
        end
    else
        pause(0.1); 
    end
end

if video_bool
    close(writerObj)
end

